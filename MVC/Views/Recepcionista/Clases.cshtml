@{
    ViewData["Title"] = "Clases";
    Layout = "~/Views/Shared/_LayoutRecepcionista.cshtml";
}

<link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datetimepicker/4.17.47/css/bootstrap-datetimepicker.min.css">
<link rel="stylesheet" href="~/css/Recepcionista/Clases.css" asp-append-version="true" />
<link rel="stylesheet" href="~/Calendario/evo-calendar/css/evo-calendar.css">
<script src="~/Calendario/evo-calendar/js/evo-calendar.js"></script>


<div class="text-center">
    <h1 class="display-4">Crear Clase</h1>
</div>
<div class="form-container-100">
    <div id="evoCalendar" class="calendar-container"></div>
    <form id="createClase" style="margin-top: 40px; display:flex; flex-direction:column; align-items: center;">
        <div class="input-container">
            <div class="form-group">
                <label for="nombreClase">Nombre de la Clase:</label>
                <input type='text' class="form-control" id="nombreClase" name="nombreClase" required />
            </div>
            <div class="form-group">
                <label for="cupos">Cupos disponibles:</label>
                <input type='text' class="form-control" id="cupos" name="cupos" required />
            </div>
            <div class="form-group">
                <label for="entrenador">Entrenador:</label>
                <select class="form-control" id="entrenador" name="entrenador" required>
                </select>
            </div>
            <div class="form-group">
                <label for="hour">Hora:</label>
                <select id="hour" class="form-control">
                    @for (int i = 6; i <= 22; i++)
                    {
                        var hour = i > 12 ? i - 12 : i;
                        var period = i < 12 ? "AM" : "PM";
                        <option value="@hour:00 @period">@hour:00 @period</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label for="date">Fecha (click en el calendario):</label>
                <input type="text" id="date" class="form-control" readonly>
            </div>
        </div>
        <button type="submit" class="btn btn-submit" id="saveBtn">Guardar</button>
    </form>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.1/moment.min.js"></script>
<script
    src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datetimepicker/4.17.47/js/bootstrap-datetimepicker.min.js"></script>
<script src="~/js/Pages/Recepcionista/Clases.js"></script>
