@{
    ViewData["Title"] = "Perfil";
    Layout = "~/Views/Shared/_LayoutRecepcionista.cshtml";
}
@model MVC.Models.UserModel

<script src="~/js/Pages/Recepcionista/PerfilUser.js" defer></script>
<link rel="stylesheet" href="~/css/Recepcionista/PerfilUser.css">

<div class="text-center">
    <h1 class="display-4">Editar Usuario</h1>
</div>

<div class="form-container">
    <form id="formUser" asp-action="CreateUser" method="post">
        <div class="row">
            <div class="col-md-6 form-group">
                <label for="nombre">Nombre</label>
                <input type="text" class="form-control" id="nombre" asp-for="Nombre"  />
            </div>
            <div class="col-md-6 form-group">
                <label for="apellido1">Apellido 1</label>
                <input type="text" class="form-control" id="apellido1" asp-for="Apellido1"  />
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 form-group">
                <label for="apellido2">Apellido 2</label>
                <input type="text" class="form-control" id="apellido2" asp-for="Apellido2"  />
            </div>
            <div class="col-md-6 form-group">
                <label for="telefono">Teléfono</label>
                <input type="text" class="form-control" id="telefono" asp-for="Telefono"  />
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 form-group">
                <label for="email">E-mail</label>
                <input type="email" class="form-control" id="email" asp-for="Email" />
            </div>
            <div class="col-md-6 form-group">
                <label>Contraseña:</label>
                <button type="button" class="btn btn-submit" id="passBtn" onclick="location.href='@Url.Action("CambiarContrasena", "Cliente")'">Cambiar</button>
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 form-group">
                <label for="cedula">Cédula</label>
                <input type="number" step="0.01" class="form-control" id="cedula" style="text-align: center" asp-for="Cedula"/>
            </div>
            <div class="col-md-6 form-group">
                <label for="rolUsuario">Rol</label>
                <select id="rolUsuario" name="rolUsuario" class="form-control" asp-for="RolUsuario">
                    <option value="Cliente">Cliente</option>
                    <option value="Entrenador">Entrenador</option>
                </select>
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 form-group">
                <label for="tipoEntrenador">Tipo de entrenador</label>
                <input type="text" class="form-control" id="tipoEntrenador" asp-for="TipoEntrenador"  />
            </div>
            <div class="col-md-6 form-group">
                <label for="tarifaHoraEntrenadorPersonal">Tarifa por Hora del Entrenador Personal </label>
                <input type="number" step="0.01" class="form-control" id="tarifaHoraEntrenadorPersonal" style="text-align: center" asp-for="TarifaHoraEntrenadorPersonal" />
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 form-group">
                <label for="estado">Estado</label>
                <select id="estado" asp-for="Estado" class="form-control">
                    <option value="true">Activo</option>
                    <option value="false">Inactivo</option>
                </select>
            </div>
            <div class="col-md-6 form-group">
                <label for="idMembresia">Id Membresía</label>
                <select id="idMembresia" class="form-control" asp-for="IdMembresia">
                    <option value="">N/A</option>
                    <option value="1">1 - Básica - 12,500.00</option>
                    <option value="2">2 - Plus - 25,000.00</option>
                    <option value="3">3 - Premium - 32,000.00</option>
                </select>
            </div>
        </div>
        <button type="submit" class="btn btn-submit">Guardar</button>
    </form>
</div>