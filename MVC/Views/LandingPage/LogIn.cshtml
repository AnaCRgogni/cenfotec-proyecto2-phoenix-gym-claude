@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = "~/Views/Shared/_LayoutLandingPage.cshtml";
}

<link rel="stylesheet" href="~/css/Cliente/LogIn.css" defer />
<script src="~/js/Pages/LandingPage/LogIn.js" defer></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11" defer></script>

<div class="form-container">
    <form id="formLogIn" class="needs-validation justify-content-center" novalidate>
        <div class="column">
            <div class="form-group">
                <label for="email">Correo</label>
                <input type="text" class="form-control" id="email" required />
                <div class="invalid-feedback">
                    Usar formato: Ejemplo@email.com
                </div>
            </div>
            <div class="form-group">
                <label for="contrasena">Contraseña</label>
                <input type="password" class="form-control" id="contrasena" required />
                <div class="invalid-feedback">
                    Debe tener al menos 8 caracteres, incluir al menos 1 letra mayúscula, números y al menos un carácter especial
                </div>
                <input type="checkbox" id="showPassword"> Mostrar Contraseña
            </div>
            <a asp-controller="LandingPage" asp-action="RecuperarContrasena">¿Olvidó su contraseña? Haga clic aquí</a>
        </div>
        <button type="submit" class="btn btn-submit" id="sendLogIn">Iniciar Sesión</button>
    </form>
</div>